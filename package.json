{
	"name": "emage-workspace",
	"private": true,
	"version": "0.2.0",
	"description": "Framework-neutral image tooling with Svelte and future framework adapters",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ItzNotABug/enhanced-img.git"
	},
	"license": "Apache-2.0",
	"type": "module",
	"packageManager": "bun@1.3.14",
	"imports": {
		"#core/*": "./packages/core/src/*",
		"#svelte/*": "./packages/svelte/src/*",
		"#test/*": "./test/*"
	},
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"lint": "prettier --check . --ignore-path .prettierignore",
		"check": "tsc",
		"format": "prettier --write --cache .",
		"test": "bun run check && bun run test:unit && bun run test:integration",
		"test:unit": "vitest run --exclude test/adapters/svelte/integration.spec.js --exclude test/adapters/svelte/dev.spec.js",
		"test:integration": "vitest run test/adapters/svelte/integration.spec.js test/adapters/svelte/dev.spec.js",
		"verify": "bun run lint && bun run test"
	},
	"devDependencies": {
		"@itznotabug/emage-core": "workspace:*",
		"@itznotabug/emage-svelte": "workspace:*",
		"@sveltejs/vite-plugin-svelte": "6.2.4",
		"@types/estree": "^1.0.8",
		"@types/node": "^22.15.0",
		"prettier": "^3.5.3",
		"prettier-plugin-svelte": "4.1.1",
		"rollup": "^4.59.0",
		"sharp": "^0.34.1",
		"svelte": "^5.0.0",
		"typescript": "^5.8.3",
		"vite": "^7.0.0",
		"vite-imagetools": "^9.0.3",
		"vitest": "^3.2.4"
	}
}
