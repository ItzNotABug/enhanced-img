{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"noEmit": true,
		"target": "es2022",
		"module": "node16",
		"moduleResolution": "node16",
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"types": ["node"]
	},
	"include": [
		"packages/*/src/**/*",
		"packages/*/types/**/*",
		"test/**/*.spec.js",
		"test/**/*.test-d.ts"
	],
	"exclude": [".research", "node_modules"]
}
